{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "Node16",

    "outDir": "dist",
    "rootDir": "src",

    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noImplicitAny": true
  },

  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}